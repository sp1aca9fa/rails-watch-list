<div class="form-page">
  <div class="form-card">
    <div class="form-card-header">
      <h1>Account Settings</h1>
      <p class="text-muted"><%= current_user.email %></p>
    </div>
    <div class="form-card-body">
      <%= simple_form_for(resource, as: resource_name, url: registration_path(resource_name), html: { method: :put }) do |f| %>
        <%= f.error_notification %>
        <%= f.input :email, required: true, autofocus: true, input_html: { autocomplete: "email" } %>
        <% if devise_mapping.confirmable? && resource.pending_reconfirmation? %>
          <p class="text-muted small">Currently waiting confirmation for: <%= resource.unconfirmed_email %></p>
        <% end %>
        <%= f.input :password, hint: "Leave blank to keep current password", required: false, input_html: { autocomplete: "new-password" } %>
        <%= f.input :password_confirmation, required: false, input_html: { autocomplete: "new-password" } %>
        <%= f.input :current_password, hint: "Required to confirm changes", required: true, input_html: { autocomplete: "current-password" } %>
        <%= f.button :submit, "Save Changes", class: "btn btn-primary btn-submit" %>
      <% end %>
      <div class="mt-4 pt-3" style="border-top: 1px solid #2E3D5A">
        <p class="text-muted small mb-2">Danger zone</p>
        <%= button_to "Delete my account", registration_path(resource_name),
              data: { turbo_confirm: "This will permanently delete your account and all your lists. Are you sure?" },
              method: :delete,
              class: "btn btn-outline-danger btn-sm" %>
      </div>
    </div>
    <div class="form-card-footer">
      <%= link_to lists_path do %>
        <i class="fa-solid fa-arrow-left me-1"></i>Back to my lists
      <% end %>
    </div>
  </div>
</div>

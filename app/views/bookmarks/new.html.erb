<div class="form-page">
  <div class="form-card">
    <div class="form-card-header">
      <h1>Add a Movie</h1>
      <p class="text-muted">Pick a film and leave a note about why it belongs here.</p>
    </div>
    <div class="form-card-body">
      <%= simple_form_for [@list, @bookmark] do |f| %>
        <%= f.association :movie, label: "Movie", prompt: "Select a movie..." %>
        <%= f.input :comment, placeholder: "What makes this one special?", label: "Your note" %>
        <%= f.submit "Add to List", class: "btn btn-primary btn-submit" %>
      <% end %>
    </div>
    <div class="form-card-footer">
      <%= link_to list_path(@list) do %>
        <i class="fa-solid fa-arrow-left me-1"></i>Back to <%= @list.name %>
      <% end %>
    </div>
  </div>
</div>

<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "WatchList" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="application-name" content="WatchList">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">

    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body>
    <nav class="navbar navbar-dark sticky-top">
      <div class="container d-flex align-items-center">
        <%= link_to root_path, class: "navbar-brand" do %>
          <i class="fa-solid fa-film me-2"></i>WatchList
        <% end %>

        <%# ── Desktop nav (md+) ─────────────────────────────────────── %>
        <div class="d-none d-md-flex ms-auto align-items-center gap-3">
          <% if user_signed_in? %>
            <%= link_to new_list_path, class: "btn btn-primary btn-sm px-3" do %>
              <i class="fa-solid fa-plus me-1"></i>New List
            <% end %>
            <div class="dropdown">
              <button class="user-avatar dropdown-toggle" type="button"
                      data-bs-toggle="dropdown" aria-expanded="false"
                      aria-label="User menu">
                <%= current_user.email[0].upcase %>
              </button>
              <ul class="dropdown-menu dropdown-menu-end user-dropdown">
                <li><h6 class="dropdown-header">My Account</h6></li>
                <li><hr class="dropdown-divider"></li>
                <li>
                  <%= link_to destroy_user_session_path, class: "dropdown-item",
                        data: { turbo_method: :delete } do %>
                    <i class="fa-solid fa-right-from-bracket me-2"></i>Sign Out
                  <% end %>
                </li>
              </ul>
            </div>
          <% else %>
            <%= link_to "Sign In", new_user_session_path, class: "nav-link" %>
            <%= link_to "Sign Up", new_user_registration_path, class: "btn btn-primary btn-sm px-3" %>
          <% end %>
        </div>

        <%# ── Mobile hamburger (< md) ───────────────────────────────── %>
        <div class="d-flex d-md-none ms-auto">
          <% if user_signed_in? %>
            <div class="dropdown">
              <button class="navbar-toggler border-0" type="button"
                      data-bs-toggle="dropdown"
                      data-bs-auto-close="outside"
                      aria-expanded="false"
                      aria-label="Toggle navigation">
                <span class="navbar-toggler-icon"></span>
              </button>
              <ul class="dropdown-menu dropdown-menu-end user-dropdown">
                <li>
                  <%= link_to new_list_path, class: "dropdown-item" do %>
                    <i class="fa-solid fa-plus me-2"></i>New List
                  <% end %>
                </li>
                <li><hr class="dropdown-divider"></li>
                <li>
                  <button class="dropdown-item d-flex justify-content-between align-items-center w-100"
                          type="button"
                          data-bs-toggle="collapse"
                          data-bs-target="#mobileAccountMenu"
                          aria-expanded="false">
                    <span><i class="fa-solid fa-user me-2"></i>My Account</span>
                    <i class="fa-solid fa-chevron-right mobile-chevron"></i>
                  </button>
                  <div class="collapse" id="mobileAccountMenu">
                    <%= link_to destroy_user_session_path,
                          class: "dropdown-item ps-4",
                          data: { turbo_method: :delete } do %>
                      <i class="fa-solid fa-right-from-bracket me-2"></i>Sign Out
                    <% end %>
                  </div>
                </li>
              </ul>
            </div>
          <% else %>
            <div class="dropdown">
              <button class="navbar-toggler border-0" type="button"
                      data-bs-toggle="dropdown"
                      aria-expanded="false"
                      aria-label="Toggle navigation">
                <span class="navbar-toggler-icon"></span>
              </button>
              <ul class="dropdown-menu dropdown-menu-end user-dropdown">
                <li><%= link_to "Sign In", new_user_session_path, class: "dropdown-item" %></li>
                <li><%= link_to "Sign Up", new_user_registration_path, class: "dropdown-item" %></li>
              </ul>
            </div>
          <% end %>
        </div>

      </div>
    </nav>

    <%# ── Confirm modal (replaces native window.confirm for turbo_confirm) ── %>
    <div class="modal fade" id="confirmModal" tabindex="-1" aria-hidden="true">
      <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content confirm-modal-content">
          <div class="modal-body confirm-modal-body">
            <i class="fa-solid fa-triangle-exclamation confirm-modal-icon"></i>
            <p class="confirm-modal-message" id="confirmModalMessage"></p>
          </div>
          <div class="modal-footer confirm-modal-footer">
            <button type="button" class="btn btn-outline-light" id="confirmModalCancel">Cancel</button>
            <button type="button" class="btn btn-danger" id="confirmModalOk">Delete</button>
          </div>
        </div>
      </div>
    </div>

    <main>
      <% flash.each do |type, message| %>
        <div class="alert alert-<%= type == 'notice' ? 'success' : 'danger' %> alert-dismissible fade show" role="alert">
          <%= message %>
          <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
      <% end %>
      <%= yield %>
    </main>
  </body>
</html>

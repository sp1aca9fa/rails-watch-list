<div class="form-page">
  <div class="form-card">
    <div class="form-card-header">
      <h1>New List</h1>
      <p class="text-muted">Give your collection a name and an optional cover photo.</p>
    </div>
    <div class="form-card-body">
      <%= simple_form_for(@list) do |f| %>
        <%= f.input :name, placeholder: "e.g. Sci-Fi Classics" %>
        <%= f.input :photo, as: :file, label: "Cover Photo (optional)" %>
        <%= f.submit "Create List", class: "btn btn-primary btn-submit" %>
      <% end %>
    </div>
    <div class="form-card-footer">
      <%= link_to lists_path do %>
        <i class="fa-solid fa-arrow-left me-1"></i>Back to lists
      <% end %>
    </div>
  </div>
</div>
